PORT=3000
CORS_ORIGIN=*

# Opção 1: URL completa
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/financeiro_db

# Opção 2: variáveis separadas (usadas se DATABASE_URL não existir)
POSTGRES_DB=financeiro_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
